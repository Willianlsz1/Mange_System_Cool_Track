# Supabase client configuration (frontend)
# Required
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_public_key

# Optional
# Bucket used for photo uploads. Default in code: registro-fotos
VITE_SUPABASE_PHOTOS_BUCKET=registro-fotos

# Signed URL TTL (seconds). Default in code: 86400 (24h)
VITE_SUPABASE_PHOTO_URL_TTL=86400

# Security note:
# Never use a service_role key in frontend code or .env files consumed by Vite.
