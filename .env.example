# Supabase client configuration (frontend)

# Required
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_public_key
VITE_AUTH_REDIRECT_URL=https://seudominio.com.br

# Optional

# Bucket used for photo uploads
# Default in code: registro-fotos
VITE_SUPABASE_PHOTOS_BUCKET=registro-fotos

# Signed URL TTL (seconds)
# Default in code: 86400 (24h)
# Controls how long uploaded photo URLs remain accessible
VITE_SUPABASE_PHOTO_URL_TTL=86400

# SECURITY:
# Never use a service_role key in frontend code or .env files consumed by Vite.
# The service_role bypasses RLS and will fully expose your database if leaked.
